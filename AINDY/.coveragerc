[run]
source = .
omit =
    */venv/*
    */.venv/*
    */site-packages/*
    tests/*
    alembic/*
    */migrations/*
    bridge/memory_bridge_rs/*
    validate_memory_loop.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    except ImportError
