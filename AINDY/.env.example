# A.I.N.D.Y. Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.

# Application
ENV=development

# Database (PostgreSQL with pgvector)
# Docker: postgresql://postgres:postgres@localhost:5433/base
DATABASE_URL=postgresql://user:password@localhost:5432/aindy_db

# MongoDB (optional — used for document storage)
MONGO_URL=mongodb://localhost:27017

# OpenAI
OPENAI_API_KEY=sk-proj-...

# DeepSeek (ARM thinking engine)
DEEPSEEK_API_KEY=ds-...

# Auth / Security
SECRET_KEY=replace-with-at-least-32-char-random-hex
PERMISSION_SECRET=replace-with-random-secret
AINDY_API_KEY=replace-with-aindy-internal-api-key

# Cache (optional)
AINDY_CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Feature flags
ENABLE_DOMAIN_APPS=false

# Nodus language runtime source path (required for /memory/nodus/execute endpoint)
# Set to the directory containing the nodus/ package
NODUS_SOURCE_PATH=/path/to/nodus/src
