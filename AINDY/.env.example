# A.I.N.D.Y. Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.

# Application
ENV=development

# Database (PostgreSQL with pgvector)
# Docker: postgresql://postgres:postgres@localhost:5433/base
DATABASE_URL=postgresql://user:password@localhost:5432/aindy_db

# MongoDB (optional — used for document storage)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek (ARM thinking engine)
DEEPSEEK_API_KEY=ds-...

# Auth / Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
PERMISSION_SECRET=replace-with-random-secret
AINDY_API_KEY=replace-with-aindy-internal-api-key

# Cache (optional)
AINDY_CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Required for Nodus script execution. Set to the directory containing the Nodus VM.
# Leave unset to disable Nodus execution (server will start but /platform/nodus/* endpoints will fail).
NODUS_SOURCE_PATH=/opt/nodus/src
