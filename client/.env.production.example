# Production environment variables for the AINDY client build.
# Copy this file to .env.production and fill in real values.
# All VITE_* variables are embedded into the bundle at build time.
# Treat them as public - do not put secrets here.

# Required: The backend API URL without trailing slash.
# Example: https://api.your-domain.com
VITE_API_BASE_URL=https://api.your-domain.com
