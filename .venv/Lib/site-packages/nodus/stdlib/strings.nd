fn upper(s) {
    return str_upper(s)
}

fn lower(s) {
    return str_lower(s)
}

fn trim(s) {
    return str_trim(s)
}

fn split(s, delimiter) {
    return str_split(s, delimiter)
}

fn contains(s, substring) {
    return str_contains(s, substring)
}

fn repeat(s, n) {
    let out = ""
    let i = 0
    while (i < n) {
        out = out + s
        i = i + 1
    }
    return out
}

fn is_blank(s) {
    return len(s) == 0
}

fn join(items, sep) {
    let out = ""
    let i = 0
    while (i < len(items)) {
        if (i > 0) {
            out = out + sep
        }
        out = out + str(items[i])
        i = i + 1
    }
    return out
}
