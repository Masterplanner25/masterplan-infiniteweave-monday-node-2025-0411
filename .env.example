# Deployment environment for the Masterplan Infinite Weave stack.
# Copy to your secret manager or local shell environment. Do not commit real values.

ENV=production

POSTGRES_DB=aindy
POSTGRES_USER=aindy
POSTGRES_PASSWORD=replace-with-strong-postgres-password

DATABASE_URL=postgresql+psycopg2://aindy:replace-with-strong-postgres-password@postgres:5432/aindy
MONGO_URL=mongodb://aindy:replace-with-strong-mongo-password@mongo:27017/aindy_social_layer?authSource=admin
MONGO_DB_NAME=aindy_social_layer
MONGO_INITDB_ROOT_USERNAME=aindy
MONGO_INITDB_ROOT_PASSWORD=replace-with-strong-mongo-password

OPENAI_API_KEY=replace-with-openai-api-key
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
SECRET_KEY=REPLACE_THIS_run_python3_-c_"import_secrets;print(secrets.token_hex(32))"
AINDY_API_KEY=replace-with-internal-service-api-key
AINDY_SERVICE_KEY=replace-with-secondary-service-api-key

ALLOWED_ORIGINS=https://your-frontend.example.com
# Change before any network-exposed deployment
REDIS_PASSWORD=changeme_in_production
REDIS_URL=redis://redis:6379/0
# Cache backend
# "redis"   - distributed cache; requires REDIS_URL; correct for multi-instance prod
# "off"     - no caching; all reads hit the database; safe for any deployment
# "memory"  - FORBIDDEN in production (multi-instance incoherence); dev-only
AINDY_CACHE_BACKEND=redis

AINDY_ENABLE_BACKGROUND_TASKS=false
AINDY_ENABLE_LEGACY_SURFACE=false
AINDY_ASYNC_HEAVY_EXECUTION=true
# Async job execution
# "thread" = single-process ThreadPool (default, suitable for dev/low-traffic)
# "distributed" = Redis-backed queue + worker process (required for multi-user prod)
EXECUTION_MODE=thread

# Number of concurrent async job threads (EXECUTION_MODE=thread only)
# For AI workloads (OpenAI/DeepSeek): each job ~10-30s, recommend >= 8
# For resource-constrained hosts: reduce to 4
AINDY_ASYNC_JOB_WORKERS=10

# Max queued jobs before 503 is returned
AINDY_ASYNC_QUEUE_MAXSIZE=100

# Per-user concurrency cap (0 = no cap, not recommended for multi-user)
AINDY_ASYNC_MAX_CONCURRENT_PER_USER=0
# Required for Nodus script execution. Set to the directory containing the Nodus VM.
# Leave unset to disable Nodus execution (server will start but /platform/nodus/* endpoints will fail).
NODUS_SOURCE_PATH=/opt/nodus/src
# Worker health probe port (default: 8001)
# WORKER_HEALTH_PORT=8001

HEALTH_CHECK_BASE_URL=http://api:8000
HEALTH_CHECK_TOKEN=replace-with-jwt-for-internal-probes-if-used
VITE_API_BASE_URL=http://localhost:8000
VITE_NETWORK_API_URL=/api/users
