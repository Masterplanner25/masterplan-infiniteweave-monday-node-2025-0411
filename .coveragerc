[run]
# id="p6h9fz"
# WARNING:
# Do not exclude production code from coverage.
# routes/, memory/, nodus/, worker/ must always be measured.
omit =
    */tests/*
    */venv/*
    */.venv/*
    */site-packages/*
    alembic/*
    */migrations/*
    tools/*
    validate_memory_loop.py
    Single File Engine.py
    Nodus_Runner.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    except ImportError
